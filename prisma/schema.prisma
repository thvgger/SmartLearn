// SmartLearn Prisma Schema
// Uses PostgreSQL for Vercel deployment

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id           String   @id @default(cuid())
    email        String   @unique
    password     String
    school_name  String
    contact_name String
    phone        String?
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt

    subscription Subscription?
    license_keys LicenseKey[]
    backups      Backup[]
    synced_users SyncedUser[]
    exams        Exam[]
    questions    Question[]
}

model Subscription {
    id         String    @id @default(cuid())
    user_id    String    @unique
    plan       String    @default("free") // free, basic, premium
    status     String    @default("inactive") // active, inactive, expired
    starts_at  DateTime?
    expires_at DateTime?
    created_at DateTime  @default(now())
    updated_at DateTime  @updatedAt

    user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model LicenseKey {
    id            String    @id @default(cuid())
    user_id       String
    key           String    @unique
    device_name   String? // optional label for the device/school PC
    is_active     Boolean   @default(true)
    last_verified DateTime?
    created_at    DateTime  @default(now())

    user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@index([user_id])
}

model Backup {
    id            String   @id @default(cuid())
    user_id       String
    license_key   String   // which CBT device created this backup
    label         String?  // optional user-facing label e.g. "Weekly Backup"
    entities      String   // comma-separated: "users,classes,tests,results"
    data          String   // the JSON payload (stored as text)
    size_bytes    Int      @default(0)
    record_count  Int      @default(0)
    is_synced     Boolean  @default(false)
    created_at    DateTime @default(now())

    user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@index([user_id])
}

model SyncedUser {
    id          String   @id @default(cuid())
    user_id     String
    name        String
    email       String?
    role        String   @default("student") // admin, teacher, student
    class_name  String   // e.g. "SS 3A", "JSS 2B"
    avg_score   Float    @default(0)
    enrolled_at DateTime @default(now())
    created_at  DateTime @default(now())
    updated_at  DateTime @updatedAt

    user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@index([user_id])
}

model Exam {
    id             String    @id @default(cuid())
    user_id        String
    title          String
    subject        String
    question_count Int       @default(0)
    duration       String    @default("1h") // e.g. "2h 30m"
    status         String    @default("draft") // draft, scheduled, completed
    scheduled_date DateTime?
    student_count  Int       @default(0)
    avg_score      Float?
    created_at     DateTime  @default(now())
    updated_at     DateTime  @updatedAt

    user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@index([user_id])
}

model Question {
    id         String   @id @default(cuid())
    user_id    String
    subject    String
    topic      String
    text       String
    options    String   @default("[]") // JSON array of option strings
    answer     String   // the correct answer
    created_at DateTime @default(now())

    user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@index([user_id])
    @@index([subject])
}
